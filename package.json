{
  "name": "daily-time-boxing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Daily Time Boxing desktop app",
  "author": "user",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --dir",
    "dist:dmg": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "lucide-react": "^0.460.0",
    "node-vibrant": "^4.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.0",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "build": {
    "appId": "com.user.dailytimeboxing",
    "productName": "Daily Time Boxing",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.productivity"
    }
  }
}
